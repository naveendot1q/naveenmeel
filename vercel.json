{
  "buildCommand": "node vercel-build.mjs",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/dist/index.mjs": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/dist/index.mjs" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ]
}
